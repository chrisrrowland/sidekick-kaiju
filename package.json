{
  "name": "mascot",
  "version": "0.1.0",
  "description": "A themeable terminal-art monster mascot for any Node/React project.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisrrowland/sidekick-kaiju.git"
  },
  "homepage": "https://chrisrrowland.github.io/sidekick-kaiju/",
  "bugs": {
    "url": "https://github.com/chrisrrowland/sidekick-kaiju/issues"
  },
  "files": [
    "dist",
    "styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./styles.css": "./styles/mascot.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:api": "node playground/scripts/generate-api-reference.mjs",
    "preplayground": "pnpm run docs:api",
    "playground": "vite",
    "prebuild:playground": "pnpm run docs:api",
    "build:playground": "vite build",
    "preview:playground": "vite preview --base=/sidekick-kaiju/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typedoc": "^0.28.20",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vitest": "^2.1.0"
  }
}
